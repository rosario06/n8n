# ==================== GEELY TRACKER - ENVIRONMENT VARIABLES ====================
# Copiar este archivo a .env.local en desarrollo o setear en Coolify

# ==================== n8n WEBHOOKS ====================
# Base URL de n8n donde están alojados los webhooks
VITE_N8N_BASE_URL=https://n8n.kelocode.com/webhook/

# Endpoints específicos de los webhooks
VITE_WEBHOOK_SAVE_INGRESO=save-ingreso
VITE_WEBHOOK_SAVE_GASTO=save-gasto
VITE_WEBHOOK_GET_ANALYSIS=get-analysis

# ==================== OPENAI ====================
# API Key para OpenAI (GPT-4o-mini)
# Nota: Idealmente esto se pasa desde backend, NO desde frontend
VITE_OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ==================== DATABASE (opcional si usas PostgreSQL local) ====================
# Si usas n8n para todo, estos no son necesarios aquí
VITE_DATABASE_HOST=db
VITE_DATABASE_PORT=5432
VITE_DATABASE_USER=geely_user
VITE_DATABASE_PASSWORD=your_secure_password
VITE_DATABASE_NAME=geely_db

# ==================== APP CONFIG ====================
VITE_APP_NAME=Geely Tracker
VITE_APP_VERSION=1.0.0
VITE_API_TIMEOUT=30000
