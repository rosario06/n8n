# Environment Variables Configuration

# COPY THIS FILE TO .env AND FILL IN YOUR VALUES

# ========================================
# N8N CORE
# ========================================
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
N8N_API_URL=https://your-n8n-instance.com/api
N8N_API_KEY=your_n8n_api_key_here

# ========================================
# WHATSAPP / TWILIO
# ========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_token

# Alternative: Meta WhatsApp Business API
WHATSAPP_BUSINESS_PHONE_ID=your_phone_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_meta_token
WHATSAPP_VERIFY_TOKEN=your_verify_token

# ========================================
# AIRTABLE
# ========================================
AIRTABLE_API_KEY=key_xxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx

# Tables in your base:
AIRTABLE_TABLE_PROPERTIES=Properties
AIRTABLE_TABLE_OWNERS=Owners
AIRTABLE_TABLE_TENANTS=Tenants
AIRTABLE_TABLE_PAYMENTS=Payments
AIRTABLE_TABLE_CONTRACTS=Contracts
AIRTABLE_TABLE_MESSAGES=Messages
AIRTABLE_TABLE_ISSUES=Issues
AIRTABLE_TABLE_STAFF=Staff
AIRTABLE_TABLE_TEMPLATES=DocumentTemplates

# ========================================
# XERO ACCOUNTING
# ========================================
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=https://your-n8n-instance.com/oauth/xero
XERO_TENANT_ID=your_xero_tenant_id
XERO_API_URL=https://api.xero.com/api.xro/2.0

# Default account for payments (where to post rent payments)
XERO_RENT_ACCOUNT_CODE=200  # Accounts Receivable or equivalent
XERO_PAYMENT_ACCOUNT_CODE=820  # Bank account

# ========================================
# OPENAI / GPT-4O
# ========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ========================================
# DATABASE (Optional - for persistent state)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/zedprop
# or
DATABASE_URL=mongodb://username:password@localhost:27017/zedprop
# or
DATABASE_URL=mysql://user:password@localhost:3306/zedprop

# ========================================
# PDF GENERATION
# ========================================
PDF_GENERATOR=puppeteer  # or "pdf-lib"
PDF_STORAGE=s3  # or "local", "gdrive"

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=zedprop-pdfs

# Google Drive (if using Google Drive)
GOOGLE_SERVICE_ACCOUNT_KEY={...json...}
GOOGLE_DRIVE_FOLDER_ID=folder_id

# Local Storage
PDF_LOCAL_PATH=./data/pdfs
PDF_PUBLIC_URL=https://your-domain.com/pdfs

# ========================================
# EMAIL (Optional - for notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@zedprop.com

# ========================================
# SECURITY
# ========================================
# JWT secret for webhook authentication
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long

# Rate limiting
RATE_LIMIT_REQUESTS=20  # requests per hour per user
RATE_LIMIT_PAYMENT_REQUESTS=5  # special limit for payment attempts

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_LEVEL=info  # debug, info, warn, error
LOG_STORAGE=database  # or "file", "console"

# Sentry (error tracking - optional)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=production

# ========================================
# BUSINESS LOGIC
# ========================================
# Default currency
DEFAULT_CURRENCY=USD

# Business hours (for automated responses outside hours)
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=America/New_York

# Payment grace period (days)
PAYMENT_GRACE_PERIOD=2  # Days before marking as overdue

# Auto-send payment reminders (days before due)
PAYMENT_REMINDER_DAYS=3

# ========================================
# FEATURE FLAGS
# ========================================
FEATURE_AI_CHAT=true
FEATURE_PDF_GENERATION=true
FEATURE_XERO_SYNC=true
FEATURE_AUTO_INVOICING=true
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_PAYMENT_GATEWAY=false

# ========================================
# DEVELOPER / TESTING
# ========================================
NODE_ENV=production  # or "development", "staging"
DEBUG=false
TEST_MODE=false

# Webhook test mode (logs requests without processing)
WEBHOOK_TEST_MODE=false

# ========================================
# INTEGRATIONS (Future Expansion)
# ========================================
# STRIPE (for payment processing)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxx

# TWILIO SMS (optional support channel)
TWILIO_SMS_FROM_NUMBER=+1234567890

# ========================================
# END OF CONFIGURATION
# ========================================

# INSTRUCTIONS TO FILL:
# 1. Copy this file: cp .env.example .env
# 2. Open .env and fill in all YOUR_xxx values
# 3. Create API keys in each service:
#    - Twilio: https://www.twilio.com/console
#    - Airtable: https://airtable.com/account/tokens
#    - Xero: https://developer.xero.com/
#    - OpenAI: https://platform.openai.com/api-keys
#    - AWS: https://console.aws.amazon.com/
# 4. Never commit .env to git
# 5. Add .env to .gitignore
# 6. Restart n8n after changing env vars
